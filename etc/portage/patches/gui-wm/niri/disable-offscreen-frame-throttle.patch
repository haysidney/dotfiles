From 8c416ed32d275d3c252dce5555002202d7c3e0aa Mon Sep 17 00:00:00 2001
From: Sidney Hays <me@sidneyhays.com>
Date: Tue, 31 Mar 2026 20:32:42 -0400
Subject: [PATCH 1/6] window-rule: add disable-offscreen-frame-throttle option

Adds a new window rule property that disables the ~1fps frame callback
throttle applied to offscreen/invisible windows, allowing specific
windows to render at full rate even when not on screen.

Co-Authored-By: Claude Sonnet 4.6 <noreply@anthropic.com>
---
 niri-config/src/window_rule.rs |  2 ++
 src/niri.rs                    | 63 +++++++++++++++++++++++++++++++---
 src/window/mod.rs              |  6 ++++
 3 files changed, 67 insertions(+), 4 deletions(-)

diff --git a/niri-config/src/window_rule.rs b/niri-config/src/window_rule.rs
index 0465d28f..b72175c3 100644
--- a/niri-config/src/window_rule.rs
+++ b/niri-config/src/window_rule.rs
@@ -72,6 +72,8 @@ pub struct WindowRule {
     pub scroll_factor: Option<FloatOrInt<0, 100>>,
     #[knuffel(child, unwrap(argument))]
     pub tiled_state: Option<bool>,
+    #[knuffel(child, unwrap(argument))]
+    pub disable_offscreen_frame_throttle: Option<bool>,
 }
 
 #[derive(knuffel::Decode, Debug, Default, Clone, PartialEq)]
diff --git a/src/niri.rs b/src/niri.rs
index e59de48b..265bb0fb 100644
--- a/src/niri.rs
+++ b/src/niri.rs
@@ -2058,8 +2058,9 @@ impl State {
                 }
             }
             CastTarget::Window { id } => {
+                let id = *id;
                 let mut windows = self.niri.layout.windows();
-                let Some((_, mapped)) = windows.find(|(_, mapped)| mapped.id().get() == *id) else {
+                let Some((_, mapped)) = windows.find(|(_, mapped)| mapped.id().get() == id) else {
                     return;
                 };
 
@@ -2075,6 +2076,10 @@ impl State {
                     .bbox_with_popups()
                     .to_physical_precise_up(scale);
 
+                // Save info needed after mapped/output borrows are released.
+                let disable_throttle = mapped.rules().disable_offscreen_frame_throttle;
+                let output_clone = output.clone();
+
                 match cast.ensure_size(bbox.size) {
                     Ok(CastSizeChange::Ready) => (),
                     Ok(CastSizeChange::Pending) => return,
@@ -2087,17 +2092,41 @@ impl State {
                     }
                 }
 
-                self.backend.with_primary_renderer(|renderer| {
+                let frame_rendered = self.backend.with_primary_renderer(|renderer| {
                     // FIXME: pointer.
                     let elements = mapped
                         .render_for_screen_cast(renderer, scale)
                         .rev()
                         .collect::<Vec<_>>();
 
-                    if cast.dequeue_buffer_and_render(renderer, &elements, bbox.size, scale) {
+                    let rendered =
+                        cast.dequeue_buffer_and_render(renderer, &elements, bbox.size, scale);
+                    if rendered {
                         cast.last_frame_time = get_monotonic_time();
                     }
-                });
+                    rendered
+                }).unwrap_or(false);
+
+                // Release the immutable layout borrow so with_windows_mut can proceed.
+                drop(windows);
+
+                // For windows with disable_offscreen_frame_throttle, send a frame callback
+                // after each cast frame to drive rendering at cast rate rather than ~1fps.
+                if frame_rendered && disable_throttle {
+                    let frame_callback_time = get_monotonic_time();
+                    self.niri.layout.with_windows_mut(|mapped, _| {
+                        if mapped.id().get() == id
+                            && mapped.rules().disable_offscreen_frame_throttle
+                        {
+                            mapped.send_frame(
+                                &output_clone,
+                                frame_callback_time,
+                                Some(Duration::ZERO),
+                                |_, _| None,
+                            );
+                        }
+                    });
+                }
             }
         }
     }
@@ -5271,6 +5300,7 @@ impl Niri {
         let scale = Scale::from(output.current_scale().fractional_scale());
 
         let mut casts_to_stop = vec![];
+        let mut throttle_callbacks: Vec<u64> = vec![];
 
         let mut casts = mem::take(&mut self.casts);
         for cast in &mut casts {
@@ -5292,6 +5322,8 @@ impl Niri {
                 .bbox_with_popups()
                 .to_physical_precise_up(scale);
 
+            let disable_throttle = mapped.rules().disable_offscreen_frame_throttle;
+
             match cast.ensure_size(bbox.size) {
                 Ok(CastSizeChange::Ready) => (),
                 Ok(CastSizeChange::Pending) => continue,
@@ -5310,10 +5342,33 @@ impl Niri {
 
             if cast.dequeue_buffer_and_render(renderer, &elements, bbox.size, scale) {
                 cast.last_frame_time = target_presentation_time;
+                if disable_throttle {
+                    throttle_callbacks.push(id);
+                }
             }
         }
         self.casts = casts;
 
+        // For windows with disable_offscreen_frame_throttle, send a frame callback after each
+        // cast frame to drive rendering at cast rate rather than the ~1fps fallback rate.
+        if !throttle_callbacks.is_empty() {
+            let frame_callback_time = get_monotonic_time();
+            for id in throttle_callbacks {
+                self.layout.with_windows_mut(|mapped, _| {
+                    if mapped.id().get() == id
+                        && mapped.rules().disable_offscreen_frame_throttle
+                    {
+                        mapped.send_frame(
+                            output,
+                            frame_callback_time,
+                            Some(Duration::ZERO),
+                            |_, _| None,
+                        );
+                    }
+                });
+            }
+        }
+
         for id in casts_to_stop {
             self.stop_cast(id);
         }
diff --git a/src/window/mod.rs b/src/window/mod.rs
index c8c358f1..cd458225 100644
--- a/src/window/mod.rs
+++ b/src/window/mod.rs
@@ -119,6 +119,9 @@ pub struct ResolvedWindowRules {
 
     /// Override whether to set the Tiled xdg-toplevel state on the window.
     pub tiled_state: Option<bool>,
+
+    /// Whether to disable the ~1fps frame callback throttle for offscreen windows.
+    pub disable_offscreen_frame_throttle: bool,
 }
 
 impl<'a> WindowRef<'a> {
@@ -296,6 +299,9 @@ impl ResolvedWindowRules {
                 if let Some(x) = rule.tiled_state {
                     resolved.tiled_state = Some(x);
                 }
+                if let Some(x) = rule.disable_offscreen_frame_throttle {
+                    resolved.disable_offscreen_frame_throttle |= x;
+                }
             }
 
             resolved.open_on_output = open_on_output.map(|x| x.to_owned());
