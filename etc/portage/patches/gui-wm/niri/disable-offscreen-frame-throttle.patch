+                if let Some(fps) = rule.offscreen_frame_throttle_rate {
+                    resolved.offscreen_frame_throttle = Some(if fps == 0 {
+                        Duration::ZERO
+                    } else {
+                        Duration::from_secs(1) / fps
+                    });
                 }
             }
 
